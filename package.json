{
  "name": "just-a-bot",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "workspaces": [
    "shared",
    "bots/*"
  ],
  "scripts": {
    "typecheck": "npm run typecheck --workspaces --if-present",
    "discord:dev": "npm run dev -w @bots/discord",
    "discord:register": "npm run register -w @bots/discord",
    "discord:start": "npm run start -w @bots/discord"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "tsx": "4.22.3",
    "typescript": "5.7.3"
  }
}
