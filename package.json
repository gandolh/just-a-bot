{
  "name": "just-a-bot",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "workspaces": [
    "shared",
    "bots/*"
  ],
  "scripts": {
    "typecheck": "npm run typecheck --workspaces --if-present",
    "discord:dev": "npm run dev -w @bots/discord",
    "discord:register": "npm run register -w @bots/discord",
    "discord:start": "npm run start -w @bots/discord",
    "whatsapp:dev": "npm run dev -w @bots/whatsapp",
    "whatsapp:start": "npm run start -w @bots/whatsapp",
    "slack:dev": "npm run dev -w @bots/slack",
    "slack:start": "npm run start -w @bots/slack",
    "mafia-activity:dev:server": "npm run dev:server -w @bots/mafia-activity",
    "mafia-activity:dev:client": "npm run dev:client -w @bots/mafia-activity",
    "mafia-activity:build": "npm run build -w @bots/mafia-activity",
    "mafia-activity:start": "npm run start -w @bots/mafia-activity",
    "deploy:pre": "tsx deploy/index.ts pre-deploy",
    "deploy:push": "tsx deploy/index.ts deploy",
    "deploy:status": "tsx deploy/index.ts status",
    "deploy:logs": "tsx deploy/index.ts logs",
    "deploy:stop": "tsx deploy/index.ts stop"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "tsx": "4.22.3",
    "typescript": "5.7.3"
  }
}
