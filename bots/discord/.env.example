DISCORD_TOKEN=your-bot-token
CLIENT_ID=your-application-id
GUILD_ID=your-test-guild-id

# Optional: enables /ask (Ollama Cloud)
# Create a key at https://ollama.com/settings/keys
OLLAMA_API_KEY=
OLLAMA_HOST=https://ollama.com
OLLAMA_MODEL=gpt-oss:120b

# Optional: enables /mafia2 (voice-channel Activity).
# WS endpoint of the @bots/mafia-activity engine server.
# MAFIA_ACTIVITY_WS_URL=ws://localhost:3100
# Shared secret matching @bots/mafia-activity's ENGINE_AUTH_TOKEN.
# MAFIA_ACTIVITY_TOKEN=
# The Discord-registered Activity URL (shown by /mafia2 launch).
# MAFIA2_ACTIVITY_URL=
