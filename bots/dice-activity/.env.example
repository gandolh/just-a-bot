DISCORD_CLIENT_ID=your-application-id
DISCORD_CLIENT_SECRET=your-application-secret
SESSION_HMAC_KEY=run-`openssl rand -base64 32`

HTTP_PORT=3000
ENGINE_LISTEN_PORT=3100

# Shared secret the discord bot presents to /engine. Must match
# bots/discord/.env's DICE_ACTIVITY_TOKEN.
ENGINE_AUTH_TOKEN=run-`openssl rand -base64 32`
